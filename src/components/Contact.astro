---
---

<section id="contact" class="py-24" style="background: var(--color-bg);">
  <div class="container">
    <div class="text-center mb-16">
      <p class="section-label reveal">Contact</p>
      <h2 class="section-title reveal">Let's work together</h2>
      <div class="section-divider mx-auto reveal"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 max-w-4xl mx-auto">
      <!-- Left: contact info -->
      <div class="reveal space-y-6">
        <p class="text-base leading-relaxed" style="color: var(--color-muted);">
          I'm always open to new opportunities, collaborations, and interesting projects. Feel free to reach out!
        </p>

        <div class="space-y-4">
          <a
            href="mailto:tauktun628@gmail.com"
            class="flex items-center gap-3 group"
            style="color: var(--color-muted);"
          >
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-orange);"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <span class="text-sm group-hover:underline" style="color: var(--color-fg);">tauktun628@gmail.com</span>
          </a>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-teal);"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="text-sm" style="color: var(--color-fg);">Bangkok, Thailand</span>
          </div>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-bg-card); border: 1px solid var(--color-border);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-orange);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <span class="text-sm" style="color: var(--color-fg);">+66-6354-82175</span>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-3 pt-2">
          <a
            href="https://github.com/tuntauk"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 flex items-center justify-center rounded-xl transition-colors"
            style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          </a>
          <a
            href="https://linkedin.com/in/tun-tauk"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 flex items-center justify-center rounded-xl transition-colors"
            style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="reveal">
        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium" style="color: var(--color-muted);" for="contact-name">Name</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Your name"
                class="px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium" style="color: var(--color-muted);" for="contact-email">Email</label>
              <input
                id="contact-email"
                type="email"
                placeholder="you@email.com"
                class="px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium" style="color: var(--color-muted);" for="contact-subject">Subject</label>
            <input
              id="contact-subject"
              type="text"
              placeholder="What's this about?"
              class="px-4 py-3 rounded-xl text-sm outline-none transition-all"
              style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium" style="color: var(--color-muted);" for="contact-message">Message</label>
            <textarea
              id="contact-message"
              rows="5"
              placeholder="Tell me about your project..."
              class="px-4 py-3 rounded-xl text-sm outline-none transition-all resize-none"
              style="background: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-fg);"
            ></textarea>
          </div>

          <!-- Error message -->
          <p id="contact-error" class="text-sm rounded-lg px-4 py-2.5" style="display:none; background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.25);"></p>

          <button type="submit" class="btn-orange w-full justify-center py-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Focus styles ──────────────────────────────────────────────────────────
  document.querySelectorAll('#contact-form input, #contact-form textarea').forEach(el => {
    el.addEventListener('focus', () => {
      (el as HTMLElement).style.borderColor = 'var(--color-orange)';
      (el as HTMLElement).style.boxShadow = '0 0 0 3px rgba(249,115,22,0.1)';
    });
    el.addEventListener('blur', () => {
      (el as HTMLElement).style.borderColor = 'var(--color-border)';
      (el as HTMLElement).style.boxShadow = 'none';
    });
  });

  // ── Submit handler ────────────────────────────────────────────────────────
  const SEND_ICON = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>`;

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form    = e.currentTarget as HTMLFormElement;
    const btn     = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const errorEl = document.getElementById('contact-error')!;

    const name    = (document.getElementById('contact-name')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('contact-email')   as HTMLInputElement).value.trim();
    const subject = (document.getElementById('contact-subject') as HTMLInputElement).value.trim();
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();

    // Client-side validation
    if (!name || !email || !message) {
      errorEl.textContent = 'Please fill in name, email, and message.';
      errorEl.style.display = 'block';
      return;
    }

    errorEl.style.display = 'none';
    btn.disabled  = true;
    btn.innerHTML = `<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Sending…`;

    try {
      const res = await fetch('/api/contact', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ name, email, subject, message }),
      });

      const data = await res.json();

      if (res.ok) {
        btn.innerHTML = '✓ Message sent!';
        btn.style.background = 'var(--color-teal)';
        form.reset();
        setTimeout(() => {
          btn.innerHTML        = `${SEND_ICON} Send Message`;
          btn.style.background = '';
          btn.disabled         = false;
        }, 4000);
      } else {
        throw new Error(data.error || 'Something went wrong.');
      }
    } catch (err: any) {
      errorEl.textContent  = err.message ?? 'Failed to send. Please try again.';
      errorEl.style.display = 'block';
      btn.innerHTML = `${SEND_ICON} Send Message`;
      btn.disabled  = false;
    }
  });
</script>
