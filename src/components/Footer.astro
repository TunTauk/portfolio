    <p class="text-xs" style="color: var(--color-muted);">
      © {year} Tun Tauk. Built with Astro &amp; Motion.js
    </p>
    <div class="flex items-center gap-5">
      <a href="https://github.com/tuntauk" target="_blank" rel="noopener noreferrer" class="text-xs hover:underline transition-colors" style="color: var(--color-muted);">GitHub</a>
      <a href="https://linkedin.com/in/tun-tauk" target="_blank" rel="noopener noreferrer" class="text-xs hover:underline transition-colors" style="color: var(--color-muted);">LinkedIn</a>
      <a href="mailto:tauktun628@gmail.com" class="text-xs hover:underline transition-colors" style="color: var(--color-muted);">Email</a>
