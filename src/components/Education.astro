---
import { awards } from '../data/awards';

const education = [
  {
    university: 'Rangsit University',
    degree: 'Bachelor of Computer Science',
    field: 'Computer Science',
    period: '06/2024 - Present',
    location: 'Bangkok, Thailand',
    current: true,
  },
  {
    university: 'University of Computer Studies, Mandalay',
    degree: 'Bachelor of Knowledge Engineering',
    field: 'Computer Science (Final Year Student)',
    period: '12/2015 - 04/2020',
    location: 'Mandalay, Myanmar',
    current: false,
  },
];

// Lucide SVG paths for the icons used
const iconPaths: Record<string, string> = {
  medal:      '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
  award:      '<circle cx="12" cy="8" r="6"/><path d="M8.56 2.9A7 7 0 0 1 19 9v1h-1v1a1 1 0 1 1-2 0v-1h-1v-1H9v1H8v1a1 1 0 1 1-2 0v-1H5V9a7 7 0 0 1 .68-3M3 21l3-3m15 3-3-3"/><path d="M12 17v4M8 21h8"/>',
  smartphone: '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>',
  globe:      '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
};
---

<section id="education" class="py-24" style="background: var(--color-bg-card); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="reveal" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-orange);">
        Education &amp; Awards
      </p>
      <h2 class="section-title reveal">Academic Background</h2>
      <div class="reveal mx-auto mt-3" style="width: 60px; height: 3px; background: var(--color-orange); border-radius: 2px;"></div>
    </div>

    <!-- Education cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      {education.map(edu => (
        <div
          class="reveal flex flex-col gap-4 rounded-xl p-7"
          style="background: var(--color-bg); border: 1px solid var(--color-border);"
        >
          <!-- Icon + info -->
          <div class="flex items-start gap-4">
            <div class="shrink-0 flex items-center justify-center rounded-lg w-10 h-10" style="background: color-mix(in srgb, var(--color-orange) 12%, transparent);">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 class="font-semibold text-base leading-snug" style="color: var(--color-fg);">{edu.university}</h3>
              <p class="text-sm" style="color: var(--color-fg); opacity: 0.85;">{edu.degree}</p>
              <p class="text-xs" style="color: var(--color-muted);">{edu.field}</p>
            </div>
          </div>

          <!-- Period + location -->
          <div class="flex items-center gap-3 flex-wrap text-xs">
            <span class="flex items-center gap-1.5" style="color: var(--color-orange);">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
              </svg>
              {edu.period}
              {edu.current && (
                <span class="ml-1 px-1.5 py-0.5 rounded text-xs font-medium" style="background: color-mix(in srgb, var(--color-orange) 15%, transparent); color: var(--color-orange); font-size: 0.65rem;">
                  Current
                </span>
              )}
            </span>
            <span style="color: var(--color-border);">·</span>
            <span class="flex items-center gap-1.5" style="color: var(--color-muted);">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              {edu.location}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Achievements divider -->
    <div class="reveal flex items-center gap-4 mb-10">
      <div class="flex-1" style="height: 1px; background: var(--color-border);"></div>
      <span class="text-xs font-medium tracking-widest uppercase" style="color: var(--color-muted); font-family: 'JetBrains Mono', monospace;">Achievements</span>
      <div class="flex-1" style="height: 1px; background: var(--color-border);"></div>
    </div>

    <!-- Awards grid (unchanged) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {awards.map(award => (
        <div
          class="reveal flex flex-col items-center text-center gap-3 rounded-xl p-6"
          style={`background: var(--color-bg-card); border: 1px solid ${award.borderColor};`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32" height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke={award.iconColor}
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={iconPaths[award.lucideIcon]}
          />
          <h3 class="font-bold text-sm leading-snug" style="color: var(--color-fg);">{award.title}</h3>
          <p class="text-xs leading-relaxed" style="color: var(--color-muted);">{award.subtitle}</p>
        </div>
      ))}
    </div>

  </div>
</section>
