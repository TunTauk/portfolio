---
import { awards } from '../data/awards';

// Lucide SVG paths for the icons used
const iconPaths: Record<string, string> = {
  medal:      '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
  award:      '<circle cx="12" cy="8" r="6"/><path d="M8.56 2.9A7 7 0 0 1 19 9v1h-1v1a1 1 0 1 1-2 0v-1h-1v-1H9v1H8v1a1 1 0 1 1-2 0v-1H5V9a7 7 0 0 1 .68-3M3 21l3-3m15 3-3-3"/><path d="M12 17v4M8 21h8"/>',
  smartphone: '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>',
  globe:      '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
};
---

<section id="awards" class="py-24" style="background: var(--color-bg-card); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
  <div class="container">
    <div class="text-center mb-16">
      <p class="reveal" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-orange);">
        Awards
      </p>
      <h2 class="section-title reveal">Achievements &amp; Recognition</h2>
      <div class="reveal mx-auto mt-3" style="width: 60px; height: 3px; background: var(--color-orange); border-radius: 2px;"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {awards.map(award => (
        <div
          class="reveal flex flex-col items-center text-center gap-3 rounded-xl p-6"
          style={`background: var(--color-bg-card); border: 1px solid ${award.borderColor};`}
        >
          <!-- Lucide icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32" height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke={award.iconColor}
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={iconPaths[award.lucideIcon]}
          />
          <h3 class="font-bold text-sm leading-snug" style="color: var(--color-fg);">{award.title}</h3>
          <p class="text-xs leading-relaxed" style="color: var(--color-muted);">{award.subtitle}</p>
        </div>
      ))}
    </div>
  </div>
</section>
