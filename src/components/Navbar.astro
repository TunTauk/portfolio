---
const navLinks = [
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#experience", label: "Experience" },
  { href: "#projects", label: "Projects" },
  { href: "#awards", label: "Awards" },
  { href: "#contact", label: "Contact" },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: transparent;"
>
  <div class="container flex items-center justify-between h-16">
    <!-- Logo -->
    <a
      href="/"
      class="text-xl font-extrabold tracking-tight"
      style="color: var(--color-orange);"
    >
      TT
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium nav-link"
            style="color: var(--color-muted); transition: color 0.2s ease;"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-3">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="w-9 h-9 flex items-center justify-center rounded-full border transition-colors"
        style="border-color: var(--color-border); color: var(--color-muted);"
      >
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
        >
          <circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- Hire me -->
      <a
        href="#contact"
        class="hidden md:inline-flex items-center gap-1.5 text-sm font-semibold rounded-lg"
        style="background: var(--color-orange); color: #fff; padding: 6px 16px; transition: background 0.2s ease;"
      >
        Hire me
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="menu-toggle"
        aria-label="Open menu"
        class="md:hidden w-9 h-9 flex items-center justify-center rounded-full border"
        style="border-color: var(--color-border); color: var(--color-fg);"
      >
        <svg
          id="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line><line
            x1="3"
            y1="6"
            x2="21"
            y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu (display:none by default, Motion.js controls visibility) -->
  <div
    id="mobile-menu"
    class="md:hidden px-6 pb-6 pt-2"
    style="display:none; background: var(--color-bg-card); border-bottom: 1px solid var(--color-border); opacity: 0;"
  >
    <nav class="flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-sm font-medium py-1"
            style="color: var(--color-fg);"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="btn-orange text-sm text-center mt-2"
        style="padding: 6px 16px;"
      >
        Hire me
      </a>
    </nav>
  </div>
</header>

<script>
  import { animate } from "motion";

  // ── Scroll: make navbar solid after 60px ──
  const navbar = document.getElementById("navbar")!;
  function updateNavbar() {
    if (window.scrollY > 60) {
      navbar.style.background = "var(--color-bg-card)";
      navbar.style.borderBottom = "1px solid var(--color-border)";
      navbar.style.backdropFilter = "blur(12px)";
    } else {
      navbar.style.background = "transparent";
      navbar.style.borderBottom = "none";
      navbar.style.backdropFilter = "none";
    }
  }
  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();

  // ── Theme toggle with spin animation ──
  const toggleBtn = document.getElementById("theme-toggle")!;
  const iconSun = document.getElementById("icon-sun")!;
  const iconMoon = document.getElementById("icon-moon")!;

  function syncThemeIcons(animate_: typeof animate) {
    const isDark = document.documentElement.classList.contains("dark");
    // Spin out current icon, swap, spin in new icon
    const outIcon = isDark ? iconMoon : iconSun;
    const inIcon = isDark ? iconSun : iconMoon;

    animate_(
      outIcon,
      { opacity: [1, 0], rotate: [0, 180], scale: [1, 0.5] },
      { duration: 0.2 },
    ).then(() => {
      outIcon.classList.add("hidden");
      inIcon.classList.remove("hidden");
      inIcon.style.opacity = "0";
      animate_(
        inIcon,
        { opacity: [0, 1], rotate: [-180, 0], scale: [0.5, 1] },
        { duration: 0.2 },
      );
    });
  }

  // Initial icon state (no animation on load)
  const initDark = document.documentElement.classList.contains("dark");
  iconSun.classList.toggle("hidden", !initDark);
  iconMoon.classList.toggle("hidden", initDark);

  toggleBtn.addEventListener("click", () => {
    // Animate toggle button press
    animate(toggleBtn, { scale: [1, 0.85, 1] }, { duration: 0.25 });
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncThemeIcons(animate);
  });

  // ── Mobile menu with slide + fade animation ──
  const menuToggle = document.getElementById("menu-toggle")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const iconMenuEl = document.getElementById("icon-menu")!;
  const iconCloseEl = document.getElementById("icon-close")!;
  let menuOpen = false;

  function openMenu() {
    menuOpen = true;
    mobileMenu.style.display = "block";
    // Slide down + fade in
    animate(
      mobileMenu,
      { opacity: [0, 1], y: [-12, 0] },
      { duration: 0.25, ease: [0.25, 0.1, 0.25, 1] },
    );
    // Morph hamburger → X
    animate(
      iconMenuEl,
      { opacity: [1, 0], rotate: [0, -90], scale: [1, 0.6] },
      { duration: 0.18 },
    ).then(() => {
      iconMenuEl.classList.add("hidden");
      iconCloseEl.classList.remove("hidden");
      animate(
        iconCloseEl,
        { opacity: [0, 1], rotate: [90, 0], scale: [0.6, 1] },
        { duration: 0.18 },
      );
    });
  }

  function closeMenu() {
    menuOpen = false;
    // Slide up + fade out
    animate(
      mobileMenu,
      { opacity: [1, 0], y: [0, -10] },
      { duration: 0.2 },
    ).then(() => {
      mobileMenu.style.display = "none";
    });
    // Morph X → hamburger
    animate(
      iconCloseEl,
      { opacity: [1, 0], rotate: [0, 90], scale: [1, 0.6] },
      { duration: 0.18 },
    ).then(() => {
      iconCloseEl.classList.add("hidden");
      iconMenuEl.classList.remove("hidden");
      animate(
        iconMenuEl,
        { opacity: [0, 1], rotate: [-90, 0], scale: [0.6, 1] },
        { duration: 0.18 },
      );
    });
  }

  menuToggle.addEventListener("click", () => {
    animate(menuToggle, { scale: [1, 0.88, 1] }, { duration: 0.22 });
    menuOpen ? closeMenu() : openMenu();
  });

  // Close on mobile link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  // ── Active nav link highlight on scroll ──
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll("a.nav-link");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const active = link.getAttribute("href") === `#${entry.target.id}`;
            (link as HTMLElement).style.color = active
              ? "var(--color-orange)"
              : "var(--color-muted)";
          });
        }
      });
    },
    { rootMargin: "-40% 0px -55% 0px" },
  );

  sections.forEach((s) => observer.observe(s));
</script>
